# Profile-specific serial ports. These names are derived from the existing
# pytest-embedded-cli profile and peer directory names; host/device do not
# describe BLE roles.
TEST_SERIAL_PORT_S3_PEER_HOST=/dev/ttyUSB0
TEST_SERIAL_PORT_PEER_DEVICE_S3_PEER_DEVICE=/dev/ttyUSB1

# Optional single-board/manual profiles added as those tests are implemented.
TEST_SERIAL_PORT_ESP32S3=/dev/ttyACM0

#PYTEST_ADDOPTS="--html=report.html --self-contained-html"
